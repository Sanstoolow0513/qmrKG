# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
# Local git worktrees (keep empty .worktrees/ in clone via .gitkeep)
.worktrees/
!.worktrees/.gitkeep
.pytest_local/
.pytest-tmp/
.pytest_cache/
.tmp/
pytest-cache-files*/
tests/_scratch/

# Data: ignore generated artifacts; keep empty dirs with .gitkeep
data/

# Config files with sensitive data
.env

# Model files
*.pdmodel
*.pdiparams
*.pdopt
inference/


# .DS_Store
.DS_Store

# Frontend (Next.js / Node)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/.vercel/
frontend/.env*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/coverage/
frontend/.nyc_output/

# pnpm
.pnpm-store

# Thesis/reference dump and LaTeX build artifacts
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
.codex

# Local paper/reference library (large, managed outside git)
papers/*
!papers/refer-submitted/
!papers/template-of-thesis/
docs/reports/reference/
