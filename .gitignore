# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
# Local git worktrees (keep empty .worktrees/ in clone via .gitkeep)
.worktrees/
!.worktrees/.gitkeep
.pytest_local/
.pytest-tmp/
.pytest_cache/
.tmp/
pytest-cache-files*/
tests/_scratch/

# Data: ignore generated artifacts; keep empty dirs with .gitkeep
data/

# Config files with sensitive data
.env

# Model files
*.pdmodel
*.pdiparams
*.pdopt
inference/

# workspaces
.cursor/
.vscode/

# .DS_Store
.DS_Store