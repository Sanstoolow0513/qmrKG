# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
# Local git worktrees (keep empty .worktrees/ in clone via .gitkeep)
.worktrees/
!.worktrees/.gitkeep
.pytest_local/
.pytest-tmp/
.pytest_cache/
.tmp/
pytest-cache-files*/
tests/_scratch/

# Data: ignore generated artifacts; keep empty dirs with .gitkeep
data/

# Config files with sensitive data
.env

# Model files
*.pdmodel
*.pdiparams
*.pdopt
inference/

# workspaces
.cursor/
.vscode/

# .DS_Store
.DS_Store

# Frontend (Next.js / Node)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.turbo/
frontend/.vercel/
frontend/.env*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*
frontend/coverage/
frontend/.nyc_output/